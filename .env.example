# Copy to .env and fill in your values.
#
# ── Hackathon required (injected by evaluator at runtime) ────────────────────
# The LiteLLM proxy endpoint provided by the evaluator.
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference (must be available on API_BASE_URL).
MODEL_NAME=llama-3.1-8b-instant

# Your LiteLLM proxy API key (injected by evaluator at runtime).
HF_TOKEN=your_api_key_here

# ── Optional: set locally for development ────────────────────────────────────
# URL of the IncidentEnv HF Space (defaults to the production space).
INCIDENT_ENV_URL=https://atul-k-6o-incident-response-env.hf.space

# Seconds to wait between LLM requests (increase if hitting rate limits).
INCIDENT_LLM_REQUEST_DELAY_SECONDS=2

# Log verbosity: DEBUG, INFO, WARNING, ERROR.
INCIDENT_BASELINE_LOG_LEVEL=INFO
